{
  "name": "agent-action-render",
  "version": "0.1.0",
  "description": "Shared rendering helpers for agent tool, notice, and HRC action lines",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"

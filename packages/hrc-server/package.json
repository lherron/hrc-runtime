{
  "name": "hrc-server",
  "version": "0.1.0",
  "description": "HRC daemon: Unix socket HTTP API, tmux management, runtime orchestration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun ../../scripts/strip-bun-exports.ts",
    "postpack": "git checkout HEAD -- package.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "agent-scope": "0.1.1-dev.20260531143750",
    "agent-spaces": "0.1.1-dev.20260531143750",
    "hrc-core": "*",
    "hrc-events": "*",
    "hrc-store-sqlite": "*",
    "spaces-aspc": "0.1.1-dev.20260531143750",
    "spaces-aspc-protocol": "0.1.1-dev.20260531143750",
    "spaces-config": "0.1.1-dev.20260531143750",
    "spaces-execution": "0.1.1-dev.20260531143750",
    "spaces-harness-broker-client": "0.1.1-dev.20260531143750",
    "spaces-harness-broker-protocol": "0.1.1-dev.20260531143750",
    "spaces-harness-codex": "0.1.1-dev.20260531143750",
    "spaces-runtime": "0.1.1-dev.20260531143750",
    "spaces-runtime-contracts": "0.1.1-dev.20260531143750"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}

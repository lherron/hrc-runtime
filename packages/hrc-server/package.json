{
  "name": "hrc-server",
  "version": "0.1.0",
  "private": true,
  "description": "HRC daemon: Unix socket HTTP API, tmux management, runtime orchestration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prepack": "bun ../../scripts/strip-bun-exports.ts",
    "postpack": "git checkout HEAD -- package.json"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "agent-scope": "*",
    "agent-spaces": "*",
    "hrc-core": "*",
    "hrc-events": "*",
    "hrc-store-sqlite": "*",
    "spaces-config": "*",
    "spaces-execution": "*",
    "spaces-harness-codex": "*",
    "spaces-runtime": "*"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.8.3"
  }
}
